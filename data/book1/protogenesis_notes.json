  "lessons": {
    "001": {
      "main_knowledge": [
        "一般疑问句的构成形式"
      ],
      "topics": [
        {
          "title": "一般疑问句",
          "content": [
            {
              "type": "paragraph",
              "text": "一般疑问句将be动词提前,即将一般陈述句的be动词提前到句首"
            }
          ]
        }
      ]
    },
    "005": {
      "main_knowledge": [
        "特殊疑问句"
      ],
      "topics": [
        {
          "title": "特殊疑问句",
          "content": [
            {
              "type": "paragraph",
              "text": "以特殊疑问词who,what,whose,how等开头的疑问句成为特殊疑问句"
            },
            {
              "type": "paragraph",
              "text": "特殊疑问句的结构一般为: 特殊疑问词+助动词+主语+实义动词+宾语"
            }
          ]
        },
        {
          "title": "不定冠词",
          "content": [
            {
              "type": "paragraph",
              "text": "不定冠词只能用来表示名词的单数,名词的第一个音节以元音音节开头的需要用an,其他用a"
            }
          ]
        }
      ]
    },
    "007": {
      "main_knowledge": [
        "too和either的区别",
        "所有格形容词和所有格代词"
      ],
      "topics": [
        {
          "title": "too和either的区别",
          "content": [
            {
              "type": "paragraph",
              "text": "too和either都表示也的意思,但是too只能用于肯定与中,either用于否定句中"
            }
          ]
        },
        {
          "title": "名词的所有格形容词和所有格代词",
          "content": [
            {
              "type": "table",
              "headers": [
                "所有格形容词",
                "所有格代词",
                "中文译法"
              ],
              "rows": [
                [
                  "my",
                  "mine",
                  "我的"
                ],
                [
                  "your",
                  "yours",
                  "你的/你们的"
                ],
                [
