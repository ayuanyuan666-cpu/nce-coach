                  "hers",
                  "她的"
                ],
                [
                  "its",
                  "",
                  "它的"
                ],
                [
                  "our",
                  "ours",
                  "我们的"
                ],
                [
                  "their",
                  "theirs",
                  "他/她们的"
                ]
              ]
            }
          ]
        }
      ]
    },
    "013": {
      "main_knowledge": [
        "祈使句"
      ],
      "topics": [
        {
          "title": "祈使句",
          "content": [
            {
              "type": "paragraph",
              "text": "祈使句的主语通常省略,谓语动词用原形,表示请求,建议,命令等"
            },
            {
              "type": "paragraph",
              "text": "祈使句后可以跟and和另一个祈使动词,而不是跟动词不定式to"
            },
            {
              "type": "paragraph",
              "text": "例如: sweep the floor and dust the table."
            }
          ]
        }
      ]
    },
    "015": {
      "main_knowledge": [
        "名词的复数-s/-es发音规则",
        "名词的复数形式"
      ],
      "topics": [
        {
          "title": "名词的复数发音规则",
          "content": [
            {
              "type": "list",
              "ordered": true,
              "items": [
                "如果名词以清辅音结尾,发s音",
                "如果名词以浊辅音和元音结尾,发z音",
                "如果名词以/s/, /z/, /ʃ/, /ʒ/, /tʃ/, /dʒ/ 结尾的,发iz音"
              ]
            }
          ]
        },
        {
          "title": "名词的复数形式",
          "content": [
            {
              "type": "paragraph",
              "text": "名词的复数形式一般加s或es"
            },
            {
              "type": "paragraph",
              "text": "如果名词以f或者fe结尾的,需要将f或者fe改成v再加es"
            },
            {
              "type": "paragraph",
              "text": "名词的不规则复数形式"
            },
            {
              "type": "paragraph",
              "text": "例如:"
            },
            {
              "type": "list",
              "ordered": false,
              "items": [
                "man // men"
              ]
            }
          ]
        }
      ]
    },
